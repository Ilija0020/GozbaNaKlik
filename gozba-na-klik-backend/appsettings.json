    "Issuer": "http://localhost:5128",
    "Audience": "http://localhost:5128"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=gozbaNaKlikDB;Username=postgres;Password=root"
  }
}
